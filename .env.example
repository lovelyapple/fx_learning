# FX Learning App - Environment Variables
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# GitHub Models API Token (必須)
# https://github.com/settings/tokens で取得
GITHUB_TOKEN=your_github_token_here

# Twelve Data API Key (ライブ価格更新用)
# "demo" で動作します（無料。高頻度利用は https://twelvedata.com で無料登録推奨）
TWELVEDATA_API_KEY=demo

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=5173

# FX Settings
DEFAULT_PAIR=USDJPY=X
